#: ../plugins/cd/PLUGININFO:4
#, python-format
msgid ""
"Adds support for playing audio CDs.\n"
"\n"
"Requires UDisks2 to autodetect CDs\n"
"Requires python-libdiscid (%s) and python-musicbrainzngs (%s) to look up "
"tags."
msgstr ""
"Menambahkan dukungan untuk memutar CD audio.\n"
"\n"
"Memerlukan UDisks2 untuk mendeteksi CD secara otomatis\n"
"Memerlukan python-libdiscid (%s) dan python-musicbrainzngs (%s) untuk "
"mencari tag."

